// src/App.jsx
import { useState, createContext, useContext } from "react";
import Home from "./components/Home";
import Documents from "./components/Documents";
import AIScreen from "./components/AIScreen";
import Profile from "./components/Profile";
import TaskDetail from "./components/TaskDetail";
import "./App.css";

const LangCtx = createContext("en");
export const useLang = () => useContext(LangCtx);

const TABS = (t) => [
  { id: "home", icon: "🏠", label: t.navHome },
  { id: "docs", icon: "📁", label: t.navDocs },
  { id: "ai", icon: "✦", label: t.navAI },
  { id: "profile", icon: "👤", label: t.navProfile },
];

export default function LifeAdmin() {
  const [lang, setLang] = useState("en");
  const [tab, setTab] = useState("home");
  const [activeTask, setActiveTask] = useState(null);

  const t = T[lang];

  return (
    <LangCtx.Provider value={lang}>
      <div className="phone-shell">
        <div className="status-bar">
          <span>9:41</span>
          <div className="status-controls">
            <div className="lang-toggle">
              <button 
                className={`lang-btn ${lang === "en" ? "active" : ""}`} 
                onClick={() => {setLang("en"); setActiveTask(null);}}
                aria-label="Switch to English"
              >
                EN
              </button>
              <button 
                className={`lang-btn ${lang === "hi" ? "active" : ""}`} 
                onClick={() => {setLang("hi"); setActiveTask(null);}}
                aria-label="हिंदी में बदलें"
              >
                हिं
              </button>
            </div>
            <div className="status-icons">
              <span aria-label="Network signal">📶</span>
              <span aria-label="Battery level">🔋</span>
            </div>
          </div>
        </div>

        <div className="screen-container">
          {tab === "home" && <Home openTask={setActiveTask} />}
          {tab === "docs" && <Documents />}
          {tab === "ai" && <AIScreen />}
          {tab === "profile" && <Profile />}
          {activeTask && (
            <TaskDetail 
              task={activeTask} 
              onBack={() => setActiveTask(null)} 
            />
          )}
        </div>

        <nav className="bottom-nav" role="navigation" aria-label="Main navigation">
          {TABS(t).map((tabItem) => (
            <button
              key={tabItem.id}
              className={`nav-btn ${tab === tabItem.id ? "active" : ""}`}
              onClick={() => {
                setActiveTask(null);
                setTab(tabItem.id);
              }}
              aria-current={tab === tabItem.id ? "page" : undefined}
            >
              <div className="nav-icon" aria-hidden="true">{tabItem.icon}</div>
              <div className="nav-label">{tabItem.label}</div>
              {tab === tabItem.id && <div className="nav-dot" aria-hidden="true" />}
            </button>
          ))}
        </nav>
      </div>
    </LangCtx.Provider>
  );
}

